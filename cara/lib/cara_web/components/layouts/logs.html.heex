<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Cara · Audit Logs" suffix=" · Cara">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-white text-gray-900 min-h-screen">
    <nav class="border-b border-gray-200 bg-white">
      <div class="mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <.link href={~p"/logs"} class="text-lg font-semibold text-gray-900 hover:text-gray-700 transition-colors">
            Audit Logs
          </.link>
          <span class="text-gray-300">|</span>
          <.link href={~p"/"} class="text-sm text-gray-500 hover:text-gray-700 transition-colors">
            ← Back to Cara
          </.link>
        </div>
      </div>
    </nav>
    <main>
      {@inner_content}
    </main>
  </body>
</html>
