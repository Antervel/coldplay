<div class="fixed inset-0 bg-white flex flex-col items-center justify-center p-6 sm:p-12 overflow-y-auto z-[60]">
  <div class="max-w-3xl w-full text-center">
    <img
      src={~p"/images/sleeping_robot.png"}
      alt="Sleeping Robot"
      class="w-full h-auto max-h-[60vh] object-contain mb-10 mx-auto"
    />

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">The AI is Sleeping 😴</h1>
    <p class="text-lg sm:text-xl text-gray-600 mb-10">
      Our robot friend is currently taking a nap. Please check back later!
    </p>

    <.form for={%{}} action={~p"/settings/model"} method="post" class="flex justify-center items-end gap-3 mb-6">
      <select
        name="model"
        class="rounded-lg border border-gray-300 bg-white text-black px-4 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
      >
        <option value="openai:cara-cpu" selected={@current_model == "openai:cara-cpu"}>
          Ollama — cara:cpu
        </option>
        <option value="openai:openai/gpt-oss-20b" selected={@current_model == "openai:openai/gpt-oss-20b"}>
          NVIDIA — openai/gpt-oss-20b
        </option>
      </select>
      <button
        type="submit"
        class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition-colors"
      >
        Apply
      </button>
    </.form>

    <.link href="/chat" class="btn btn-primary btn-lg px-10">
      Go Back Home
    </.link>
  </div>
</div>
